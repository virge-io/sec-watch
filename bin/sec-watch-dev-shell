#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UUID="sec-watch@local"

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

shell_major_version() {
  gnome-shell --version | awk '{print int($3)}'
}

require_command awk
require_command dbus-run-session
require_command gnome-extensions
require_command gnome-shell

"$ROOT/install.sh"

export G_MESSAGES_DEBUG="${G_MESSAGES_DEBUG:-all}"
export SHELL_DEBUG="${SHELL_DEBUG:-all}"

shell_argv=(gnome-shell)
if [[ "$(shell_major_version)" -ge 49 ]]; then
  shell_argv+=(--devkit)
else
  shell_argv+=(--nested)
fi
shell_argv+=(--wayland)

exec dbus-run-session -- bash -c '
set -euo pipefail

uuid="$1"
shift

"$@" &
shell_pid=$!

cleanup() {
  if kill -0 "$shell_pid" >/dev/null 2>&1; then
    kill "$shell_pid" >/dev/null 2>&1 || true
  fi
}
trap cleanup INT TERM

for _ in {1..50}; do
  if gnome-extensions list >/dev/null 2>&1; then
    gnome-extensions enable "$uuid" >/dev/null 2>&1 || true
    break
  fi
  sleep 0.2
done

wait "$shell_pid"
' sec-watch-dev-session "$UUID" "${shell_argv[@]}"
