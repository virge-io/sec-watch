#!/usr/bin/env bash
set -uo pipefail

PROJECTS_DIR="${SEC_WATCH_PROJECTS_DIR:-${PROJECTS_DIR:-$HOME/Projects}}"
if [[ -v SEC_WATCH_ECOSYSTEMS ]]; then
  ENABLED_ECOSYSTEMS="$SEC_WATCH_ECOSYSTEMS"
  ECOSYSTEM_FILTER_SET=1
else
  ENABLED_ECOSYSTEMS=""
  ECOSYSTEM_FILTER_SET=0
fi
SELECTED_PROJECTS="${SEC_WATCH_PROJECTS:-}"
if [[ -v SEC_WATCH_PUBLIC_FEEDS ]]; then
  PUBLIC_FEEDS="$SEC_WATCH_PUBLIC_FEEDS"
else
  PUBLIC_FEEDS="manual,cisa-kev,nvd-recent"
fi
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/sec-watch"
CACHE_FILE="$CACHE_DIR/status.env"
DEP_REPORT_FILE="$CACHE_DIR/dependency-report.txt"
DEP_HTML_REPORT_FILE="$CACHE_DIR/dependency-report.html"
DEP_JSON_FILE="$CACHE_DIR/dependency-report.json"
WATCH_CONFIG="${SEC_WATCH_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/sec-watch/watch.json}"
TTL_SECONDS="${SEC_WATCH_TTL:-1800}"
RECENT_DAYS="${SEC_WATCH_RECENT_DAYS:-7}"
CISA_KEV_URL="https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json"
NVD_RECENT_URL="https://nvd.nist.gov/feeds/json/cve/2.0/nvdcve-2.0-recent.json.gz"

mkdir -p "$CACHE_DIR"

now="$(date +%s)"
if [[ -f "$CACHE_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CACHE_FILE"
fi

fetch_url() {
  curl -fsSL --connect-timeout 5 --max-time 20 "$1" 2>/dev/null || true
}

feed_enabled() {
  case ",$PUBLIC_FEEDS," in
    *",$1,"*) return 0 ;;
    *) return 1 ;;
  esac
}

keywords_regex() {
  if [[ -f "$WATCH_CONFIG" ]]; then
    jq -r '.keywords // [] | map(gsub("[^A-Za-z0-9_.+-]"; "\\\\W+")) | join("|")' "$WATCH_CONFIG" 2>/dev/null
  fi
}

count_manual_watch_cves() {
  [[ -f "$WATCH_CONFIG" ]] || {
    printf '0'
    return
  }

  jq -r '.manual_cves // [] | .[].id' "$WATCH_CONFIG" 2>/dev/null |
    while read -r cve; do
      [[ -n "$cve" ]] || continue
      if command -v dnf5 >/dev/null 2>&1 &&
        ! dnf5 advisory list --all --security --with-cve --cves="$cve" 2>/dev/null | grep -q 'No advisory found'; then
        printf '%s\n' "$cve"
      else
        printf '%s\n' "$cve"
      fi
    done |
    awk 'NF {count++} END {print count + 0}'
}

count_cisa_kev_matches() {
  local regex lookback since data

  regex="$(keywords_regex)"
  [[ -n "$regex" ]] || {
    printf '0'
    return
  }

  lookback="${1:-$(jq -r '.lookback_days // 14' "$WATCH_CONFIG" 2>/dev/null || printf '14')}"
  since="$(date -d "$lookback days ago" '+%Y-%m-%d')"
  data="$(fetch_url "$CISA_KEV_URL")"
  [[ -n "$data" ]] || {
    printf '0'
    return
  }

  printf '%s\n' "$data" |
    jq --arg regex "$regex" --arg since "$since" '
      [.vulnerabilities[]?
        | select((.dateAdded // "0000-00-00") >= $since)
        | select(([.cveID, .vendorProject, .product, .vulnerabilityName, .shortDescription] | join(" ")) | test($regex; "i"))]
      | length
    ' 2>/dev/null || printf '0'
}

count_nvd_recent_matches() {
  local regex since data

  regex="$(keywords_regex)"
  [[ -n "$regex" ]] || {
    printf '0'
    return
  }

  since="$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')"
  data="$(fetch_url "$NVD_RECENT_URL" | gzip -dc 2>/dev/null || true)"
  [[ -n "$data" ]] || {
    printf '0'
    return
  }

  printf '%s\n' "$data" |
    jq --arg regex "$regex" --arg since "$since" '
      [.vulnerabilities[]?
        | select((.cve.vulnStatus // "") != "Rejected")
        | select(((.cve.lastModified // .cve.published // "")[0:10]) >= $since)
        | select(([.cve.id, (.cve.descriptions[]?.value // "")] | join(" ")) | test($regex; "i"))
        | select([
            .cve.metrics.cvssMetricV31[]?.cvssData.baseSeverity,
            .cve.metrics.cvssMetricV30[]?.cvssData.baseSeverity,
            .cve.metrics.cvssMetricV2[]?.baseSeverity
          ] | any(. == "HIGH" or . == "CRITICAL"))
      ]
      | length
    ' 2>/dev/null || printf '0'
}

format_recent_suffix() {
  if [[ "${1:-0}" -gt 0 ]]; then
    printf ' ↑%s' "$1"
  fi
}

filter_trivy_json() {
  local json="$1"

  printf '%s\n' "$json" |
    jq --arg ecosystems "$ENABLED_ECOSYSTEMS" --arg ecosystem_filter_set "$ECOSYSTEM_FILTER_SET" --arg projects "$SELECTED_PROJECTS" '
      def csv_values($value): $value | split(",") | map(select(length > 0));

      csv_values($ecosystems) as $ecosystem_ids
      | csv_values($projects) as $project_names
      | .Results = [
          .Results[]?
          | select(
              $ecosystem_filter_set != "1" or
              (($ecosystem_ids | length) > 0 and (.Type as $type | $ecosystem_ids | index($type)))
            )
          | select(
              ($project_names | length) == 0 or
              (.Target as $target | ($project_names | map(. as $project | select(($target == $project) or ($target | startswith($project + "/")))) | length) > 0)
            )
        ]
    ' 2>/dev/null || printf '%s\n' "$json"
}

ecosystem_selected() {
  if [[ "$ECOSYSTEM_FILTER_SET" != "1" ]]; then
    return 0
  fi

  case ",$ENABLED_ECOSYSTEMS," in
    *",$1,"*) return 0 ;;
    *) return 1 ;;
  esac
}

should_watch_dependency_file() {
  local path="$1"
  local name="${path##*/}"

  case "$name" in
    package-lock.json)
      ecosystem_selected npm
      ;;
    package.json)
      ecosystem_selected npm || ecosystem_selected yarn || ecosystem_selected pnpm
      ;;
    yarn.lock)
      ecosystem_selected yarn
      ;;
    pnpm-lock.yaml|pnpm-lock.yml)
      ecosystem_selected pnpm
      ;;
    requirements*.txt|Pipfile.lock)
      ecosystem_selected pip
      ;;
    poetry.lock)
      ecosystem_selected poetry
      ;;
    uv.lock)
      ecosystem_selected uv
      ;;
    pyproject.toml)
      ecosystem_selected pip || ecosystem_selected poetry || ecosystem_selected uv
      ;;
    *)
      return 1
      ;;
  esac
}

list_dependency_watch_files() {
  local roots=()
  local project root

  if [[ -n "$SELECTED_PROJECTS" ]]; then
    IFS=',' read -r -a roots <<< "$SELECTED_PROJECTS"
    for project in "${roots[@]}"; do
      root="$PROJECTS_DIR/$project"
      [[ -d "$root" ]] || continue
      find "$root" \
        \( -path '*/.git' -o -path '*/node_modules' -o -path '*/.venv' -o -path '*/venv' \) -prune -o \
        -type f \( \
          -name 'package-lock.json' -o -name 'package.json' -o -name 'yarn.lock' -o \
          -name 'pnpm-lock.yaml' -o -name 'pnpm-lock.yml' -o -name 'requirements*.txt' -o \
          -name 'Pipfile.lock' -o -name 'poetry.lock' -o -name 'uv.lock' -o -name 'pyproject.toml' \
        \) -print 2>/dev/null
    done
  elif [[ -d "$PROJECTS_DIR" ]]; then
    find "$PROJECTS_DIR" \
      \( -path '*/.git' -o -path '*/node_modules' -o -path '*/.venv' -o -path '*/venv' \) -prune -o \
      -type f \( \
        -name 'package-lock.json' -o -name 'package.json' -o -name 'yarn.lock' -o \
        -name 'pnpm-lock.yaml' -o -name 'pnpm-lock.yml' -o -name 'requirements*.txt' -o \
        -name 'Pipfile.lock' -o -name 'poetry.lock' -o -name 'uv.lock' -o -name 'pyproject.toml' \
      \) -print 2>/dev/null
  fi |
    while IFS= read -r path; do
      if should_watch_dependency_file "$path"; then
        printf '%s\n' "$path"
      fi
    done |
    sort -u
}

write_trivy_dependency_report() {
  local json="$1"
  local generated
  local trivy_jq_defs

  generated="$(date '+%Y-%m-%d %H:%M:%S')"
  trivy_jq_defs='
    def severity_rank($severity):
      if $severity == "CRITICAL" then 0
      elif $severity == "HIGH" then 1
      elif $severity == "MEDIUM" then 2
      elif $severity == "LOW" then 3
      else 4 end;

    def metric($vector; $key):
      (($vector // "" | split("/") | map(select(startswith($key + ":"))) | first) // "" | split(":")[1]) // "";

    def attack_vector_label($code):
      if $code == "N" then "Network"
      elif $code == "A" then "Adjacent"
      elif $code == "L" then "Local"
      elif $code == "P" then "Physical"
      else "-" end;

    def attack_vector_rank($code):
      if $code == "N" then 0
      elif $code == "A" then 1
      elif $code == "L" then 2
      elif $code == "P" then 3
      else 9 end;

    def complexity_label($code):
      if $code == "L" then "Low"
      elif $code == "M" then "Medium"
      elif $code == "H" then "High"
      else "-" end;

    def complexity_rank($code):
      if $code == "L" then 0
      elif $code == "M" then 1
      elif $code == "H" then 2
      else 9 end;

    def privilege_label($code):
      if $code == "N" then "None"
      elif $code == "L" then "Low"
      elif $code == "H" then "High"
      else "-" end;

    def privilege_rank($code):
      if $code == "N" then 0
      elif $code == "L" then 1
      elif $code == "H" then 2
      else 9 end;

    def authentication_label($code):
      if $code == "N" then "Auth: None"
      elif $code == "S" then "Auth: Single"
      elif $code == "M" then "Auth: Multiple"
      else "-" end;

    def authentication_rank($code):
      if $code == "N" then 0
      elif $code == "S" then 1
      elif $code == "M" then 2
      else 9 end;

    def interaction_label($code):
      if $code == "N" then "None"
      elif $code == "R" then "Required"
      elif $code == "P" then "Passive"
      elif $code == "A" then "Active"
      else "-" end;

    def interaction_rank($code):
      if $code == "N" then 0
      elif $code == "P" then 1
      elif $code == "R" then 2
      elif $code == "A" then 3
      else 9 end;

    def cvss_entry:
      (.CVSS // {}
        | to_entries
        | map({
            source: .key,
            score: ((.value.V4Score // .value.V3Score // .value.V2Score // 0) | tonumber? // 0),
            vector: (.value.V4Vector // .value.V3Vector // .value.V2Vector // "")
          })
        | sort_by(.score)
        | reverse
        | first) // {source: "", score: -1, vector: ""};

    def cvss_summary:
      cvss_entry as $cvss
      | ($cvss.vector // "") as $vector
      | metric($vector; "AV") as $attack_vector
      | metric($vector; "AC") as $complexity
      | metric($vector; "PR") as $privileges
      | metric($vector; "Au") as $authentication
      | metric($vector; "UI") as $interaction
      | {
          score: (if ($cvss.score // -1) >= 0 then ($cvss.score | tostring) else "-" end),
          score_sort: ($cvss.score // -1),
          vector: (if $vector != "" then $vector else "-" end),
          attack_vector: attack_vector_label($attack_vector),
          attack_vector_rank: attack_vector_rank($attack_vector),
          attack_complexity: complexity_label($complexity),
          attack_complexity_rank: complexity_rank($complexity),
          privileges: (if $privileges != "" then privilege_label($privileges) else authentication_label($authentication) end),
          privileges_rank: (if $privileges != "" then privilege_rank($privileges) else authentication_rank($authentication) end),
          user_interaction: interaction_label($interaction),
          user_interaction_rank: interaction_rank($interaction)
        };

    def finding($target):
      cvss_summary as $cvss
      | {
          rank: severity_rank(.Severity),
          severity: .Severity,
          package: .PkgName,
          installed: (.InstalledVersion // "-"),
          fixed: (.FixedVersion // "-"),
          target: $target,
          id: .VulnerabilityID,
          url: (.PrimaryURL // ""),
          title: ((.Title // .Description // "") | gsub("[\t\r\n]+"; " ")),
          cvss_score: $cvss.score,
          cvss_score_sort: $cvss.score_sort,
          cvss_vector: $cvss.vector,
          attack_vector: $cvss.attack_vector,
          attack_vector_rank: $cvss.attack_vector_rank,
          attack_complexity: $cvss.attack_complexity,
          attack_complexity_rank: $cvss.attack_complexity_rank,
          privileges: $cvss.privileges,
          privileges_rank: $cvss.privileges_rank,
          user_interaction: $cvss.user_interaction,
          user_interaction_rank: $cvss.user_interaction_rank
        };
  '

  {
    printf 'Security dependency report\n'
    printf 'Generated: %s\n' "$generated"
    printf 'Projects: %s\n' "$PROJECTS_DIR"
    printf 'Scanner: trivy\n'
    printf '\n'
    printf 'Summary\n'
    printf 'Critical: %s\n' "$DEP_CRITICAL_COUNT"
    printf 'High: %s\n' "$DEP_HIGH_COUNT"
    printf 'Medium: %s\n' "$DEP_MEDIUM_COUNT"
    printf 'Low: %s\n' "$DEP_LOW_COUNT"
    printf 'Total: %s\n' "$DEP_COUNT"
    printf 'Recent high/critical changes (%s days): %s\n' "$RECENT_DAYS" "$DEP_RECENT_COUNT"
    printf '\n'
    printf 'Recent important changes\n'
    printf '#\tSeverity\tChanged\tCVSS\tAttack vector\tComplexity\tPrivileges\tUser action\tPackage\tInstalled\tFixed\tTarget\tVulnerability\tTitle\n'
    printf '%s\n' "$json" |
      jq -r --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" "${trivy_jq_defs}"'
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | select(.Severity == "CRITICAL" or .Severity == "HIGH")
          | select(((.LastModifiedDate // .PublishedDate // "")[0:10]) >= $since)
          | finding($target) + {changed: ((.LastModifiedDate // .PublishedDate // "-")[0:10])}]
        | sort_by(.changed, .rank, .package, .id)
        | reverse
        | to_entries[]
        | [(.key + 1), .value.severity, .value.changed, .value.cvss_score, .value.attack_vector, .value.attack_complexity, .value.privileges, .value.user_interaction, .value.package, .value.installed, .value.fixed, .value.target, .value.id, (.value.title | .[0:160])]
        | @tsv
      ' 2>/dev/null
    printf '\n'
    printf 'Important findings\n'
    printf '#\tSeverity\tCVSS\tAttack vector\tComplexity\tPrivileges\tUser action\tPackage\tInstalled\tFixed\tTarget\tVulnerability\tTitle\n'
    printf '%s\n' "$json" |
      jq -r "${trivy_jq_defs}"'
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | select(.Severity == "CRITICAL" or .Severity == "HIGH")
          | finding($target)]
        | sort_by(.rank, .package, .id)
        | to_entries[]
        | [(.key + 1), .value.severity, .value.cvss_score, .value.attack_vector, .value.attack_complexity, .value.privileges, .value.user_interaction, .value.package, .value.installed, .value.fixed, .value.target, .value.id, (.value.title | .[0:160])]
        | @tsv
      ' 2>/dev/null
    printf '\n'
    printf 'All findings\n'
    printf '#\tSeverity\tCVSS\tAttack vector\tComplexity\tPrivileges\tUser action\tPackage\tInstalled\tFixed\tTarget\tVulnerability\tTitle\n'
    printf '%s\n' "$json" |
      jq -r "${trivy_jq_defs}"'
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | finding($target)]
        | sort_by(.rank, .package, .id)
        | to_entries[]
        | [(.key + 1), .value.severity, .value.cvss_score, .value.attack_vector, .value.attack_complexity, .value.privileges, .value.user_interaction, .value.package, .value.installed, .value.fixed, .value.target, .value.id, (.value.title | .[0:160])]
        | @tsv
      ' 2>/dev/null
  } > "$DEP_REPORT_FILE"

  {
    printf '%s\n' '<!doctype html>'
    printf '%s\n' '<html lang="en"><head><meta charset="utf-8">'
    printf '%s\n' '<title>Security Dependency Report</title>'
    printf '%s\n' '<style>'
    printf '%s\n' 'body{font:14px system-ui,sans-serif;margin:24px;color:#202124;background:#fff;}'
    printf '%s\n' 'h1{font-size:22px;margin:0 0 8px;} h2{font-size:18px;margin-top:28px;}'
    printf '%s\n' '.meta{color:#5f6368;margin-bottom:18px;} .summary{display:flex;gap:10px;flex-wrap:wrap;margin:16px 0;}'
    printf '%s\n' '.pill{border:1px solid #dadce0;border-radius:6px;padding:6px 10px;background:#f8f9fa;}'
    printf '%s\n' '.table-wrap{overflow-x:auto;margin-bottom:8px;} table{border-collapse:collapse;width:100%;min-width:1620px;table-layout:fixed;} th,td{border-bottom:1px solid #e0e0e0;padding:6px 8px;text-align:left;vertical-align:top;}'
    printf '%s\n' 'th{position:sticky;top:0;background:#f8f9fa;z-index:1;} th[data-sort]{cursor:pointer;user-select:none;} th[aria-sort="ascending"]::after{content:" ^";color:#5f6368;} th[aria-sort="descending"]::after{content:" v";color:#5f6368;} td{word-break:break-word;} .num{width:48px;color:#5f6368;text-align:right;}'
    printf '%s\n' '.sev-CRITICAL{color:#b00020;font-weight:700;} .sev-HIGH{color:#d84315;font-weight:700;}'
    printf '%s\n' '.fixed{width:120px}.version{width:100px}.date{width:100px}.vuln{width:145px}.severity{width:90px}.score{width:70px}.attack{width:110px}.complexity{width:95px}.privileges{width:105px}.interaction{width:105px}.target{width:230px}.package{width:145px}'
    printf '%s\n' '</style></head><body>'
    printf '<h1>%s</h1>\n' 'Security Dependency Report'
    printf '<div class="meta">Generated: %s<br>Projects: %s<br>Scanner: trivy</div>\n' "$generated" "$PROJECTS_DIR"
    printf '%s\n' '<div class="summary">'
    printf '<div class="pill">Critical: %s</div>\n' "$DEP_CRITICAL_COUNT"
    printf '<div class="pill">High: %s</div>\n' "$DEP_HIGH_COUNT"
    printf '<div class="pill">Medium: %s</div>\n' "$DEP_MEDIUM_COUNT"
    printf '<div class="pill">Low: %s</div>\n' "$DEP_LOW_COUNT"
    printf '<div class="pill">Total: %s</div>\n' "$DEP_COUNT"
    printf '<div class="pill">Recent high/critical changes: %s</div>\n' "$DEP_RECENT_COUNT"
    printf '%s\n' '</div>'
    printf '%s\n' '<h2>Recent Important Changes</h2>'
    printf '%s\n' '<div class="table-wrap"><table class="sortable"><thead><tr><th class="num" data-sort="number">#</th><th class="severity" data-sort="number">Severity</th><th class="date" data-sort="text">Changed</th><th class="score" data-sort="number">CVSS</th><th class="attack" data-sort="number">Attack vector</th><th class="complexity" data-sort="number">Complexity</th><th class="privileges" data-sort="number">Privileges</th><th class="interaction" data-sort="number">User action</th><th class="package" data-sort="text">Package</th><th class="version" data-sort="text">Installed</th><th class="fixed" data-sort="text">Fixed</th><th class="target" data-sort="text">Target</th><th class="vuln" data-sort="text">Vulnerability</th><th data-sort="text">Title</th></tr></thead><tbody>'
    printf '%s\n' "$json" |
      jq -r --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" "${trivy_jq_defs}"'
        def esc: tostring | gsub("&"; "&amp;") | gsub("<"; "&lt;") | gsub(">"; "&gt;") | gsub("\""; "&quot;");
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | select(.Severity == "CRITICAL" or .Severity == "HIGH")
          | select(((.LastModifiedDate // .PublishedDate // "")[0:10]) >= $since)
          | finding($target) + {changed: ((.LastModifiedDate // .PublishedDate // "-")[0:10])}]
        | sort_by(.changed, .rank, .package, .id)
        | reverse
        | to_entries[]
        | "<tr><td class=\"num\" data-sort-value=\"\(.key + 1)\">\(.key + 1)</td><td class=\"sev-\(.value.severity)\" data-sort-value=\"\(.value.rank)\">\(.value.severity | esc)</td><td class=\"date\" data-sort-value=\"\(.value.changed | esc)\">\(.value.changed | esc)</td><td class=\"score\" data-sort-value=\"\(.value.cvss_score_sort)\"><span title=\"\(.value.cvss_vector | esc)\">\(.value.cvss_score | esc)</span></td><td class=\"attack\" data-sort-value=\"\(.value.attack_vector_rank)\">\(.value.attack_vector | esc)</td><td class=\"complexity\" data-sort-value=\"\(.value.attack_complexity_rank)\">\(.value.attack_complexity | esc)</td><td class=\"privileges\" data-sort-value=\"\(.value.privileges_rank)\">\(.value.privileges | esc)</td><td class=\"interaction\" data-sort-value=\"\(.value.user_interaction_rank)\">\(.value.user_interaction | esc)</td><td>\(.value.package | esc)</td><td>\(.value.installed | esc)</td><td>\(.value.fixed | esc)</td><td>\(.value.target | esc)</td><td><a href=\"\(.value.url | esc)\">\(.value.id | esc)</a></td><td>\(.value.title | esc)</td></tr>"
      ' 2>/dev/null
    printf '%s\n' '</tbody></table></div>'
    printf '%s\n' '<h2>Important Findings</h2>'
    printf '%s\n' '<div class="table-wrap"><table class="sortable"><thead><tr><th class="num" data-sort="number">#</th><th class="severity" data-sort="number">Severity</th><th class="score" data-sort="number">CVSS</th><th class="attack" data-sort="number">Attack vector</th><th class="complexity" data-sort="number">Complexity</th><th class="privileges" data-sort="number">Privileges</th><th class="interaction" data-sort="number">User action</th><th class="package" data-sort="text">Package</th><th class="version" data-sort="text">Installed</th><th class="fixed" data-sort="text">Fixed</th><th class="target" data-sort="text">Target</th><th class="vuln" data-sort="text">Vulnerability</th><th data-sort="text">Title</th></tr></thead><tbody>'
    printf '%s\n' "$json" |
      jq -r "${trivy_jq_defs}"'
        def esc: tostring | gsub("&"; "&amp;") | gsub("<"; "&lt;") | gsub(">"; "&gt;") | gsub("\""; "&quot;");
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | select(.Severity == "CRITICAL" or .Severity == "HIGH")
          | finding($target)]
        | sort_by(.rank, .package, .id)
        | to_entries[]
        | "<tr><td class=\"num\" data-sort-value=\"\(.key + 1)\">\(.key + 1)</td><td class=\"sev-\(.value.severity)\" data-sort-value=\"\(.value.rank)\">\(.value.severity | esc)</td><td class=\"score\" data-sort-value=\"\(.value.cvss_score_sort)\"><span title=\"\(.value.cvss_vector | esc)\">\(.value.cvss_score | esc)</span></td><td class=\"attack\" data-sort-value=\"\(.value.attack_vector_rank)\">\(.value.attack_vector | esc)</td><td class=\"complexity\" data-sort-value=\"\(.value.attack_complexity_rank)\">\(.value.attack_complexity | esc)</td><td class=\"privileges\" data-sort-value=\"\(.value.privileges_rank)\">\(.value.privileges | esc)</td><td class=\"interaction\" data-sort-value=\"\(.value.user_interaction_rank)\">\(.value.user_interaction | esc)</td><td>\(.value.package | esc)</td><td>\(.value.installed | esc)</td><td>\(.value.fixed | esc)</td><td>\(.value.target | esc)</td><td><a href=\"\(.value.url | esc)\">\(.value.id | esc)</a></td><td>\(.value.title | esc)</td></tr>"
      ' 2>/dev/null
    printf '%s\n' '</tbody></table></div>'
    printf '%s\n' '<h2>All Findings</h2>'
    printf '%s\n' '<div class="table-wrap"><table class="sortable"><thead><tr><th class="num" data-sort="number">#</th><th class="severity" data-sort="number">Severity</th><th class="score" data-sort="number">CVSS</th><th class="attack" data-sort="number">Attack vector</th><th class="complexity" data-sort="number">Complexity</th><th class="privileges" data-sort="number">Privileges</th><th class="interaction" data-sort="number">User action</th><th class="package" data-sort="text">Package</th><th class="version" data-sort="text">Installed</th><th class="fixed" data-sort="text">Fixed</th><th class="target" data-sort="text">Target</th><th class="vuln" data-sort="text">Vulnerability</th><th data-sort="text">Title</th></tr></thead><tbody>'
    printf '%s\n' "$json" |
      jq -r "${trivy_jq_defs}"'
        def esc: tostring | gsub("&"; "&amp;") | gsub("<"; "&lt;") | gsub(">"; "&gt;") | gsub("\""; "&quot;");
        [.Results[]?
          | .Target as $target
          | .Vulnerabilities[]?
          | finding($target)]
        | sort_by(.rank, .package, .id)
        | to_entries[]
        | "<tr><td class=\"num\" data-sort-value=\"\(.key + 1)\">\(.key + 1)</td><td class=\"sev-\(.value.severity)\" data-sort-value=\"\(.value.rank)\">\(.value.severity | esc)</td><td class=\"score\" data-sort-value=\"\(.value.cvss_score_sort)\"><span title=\"\(.value.cvss_vector | esc)\">\(.value.cvss_score | esc)</span></td><td class=\"attack\" data-sort-value=\"\(.value.attack_vector_rank)\">\(.value.attack_vector | esc)</td><td class=\"complexity\" data-sort-value=\"\(.value.attack_complexity_rank)\">\(.value.attack_complexity | esc)</td><td class=\"privileges\" data-sort-value=\"\(.value.privileges_rank)\">\(.value.privileges | esc)</td><td class=\"interaction\" data-sort-value=\"\(.value.user_interaction_rank)\">\(.value.user_interaction | esc)</td><td>\(.value.package | esc)</td><td>\(.value.installed | esc)</td><td>\(.value.fixed | esc)</td><td>\(.value.target | esc)</td><td><a href=\"\(.value.url | esc)\">\(.value.id | esc)</a></td><td>\(.value.title | esc)</td></tr>"
      ' 2>/dev/null
    printf '%s\n' '</tbody></table></div>'
    printf '%s\n' '<script>'
    printf '%s\n' '(() => {'
    printf '%s\n' '  const cellValue = (row, index) => row.children[index]?.dataset.sortValue ?? row.children[index]?.textContent.trim() ?? "";'
    printf '%s\n' '  const coerce = (value, type) => {'
    printf '%s\n' '    if (type === "number") {'
    printf '%s\n' '      const number = Number.parseFloat(value);'
    printf '%s\n' '      return Number.isNaN(number) ? -1 : number;'
    printf '%s\n' '    }'
    printf '%s\n' '    return value.toLocaleLowerCase();'
    printf '%s\n' '  };'
    printf '%s\n' '  document.querySelectorAll("table.sortable").forEach(table => {'
    printf '%s\n' '    table.querySelectorAll("th[data-sort]").forEach((th, index) => {'
    printf '%s\n' '      th.tabIndex = 0;'
    printf '%s\n' '      const sort = () => {'
    printf '%s\n' '        const tbody = table.tBodies[0];'
    printf '%s\n' '        const direction = th.dataset.direction === "asc" ? "desc" : "asc";'
    printf '%s\n' '        const multiplier = direction === "asc" ? 1 : -1;'
    printf '%s\n' '        const type = th.dataset.sort || "text";'
    printf '%s\n' '        const rows = Array.from(tbody.rows);'
    printf '%s\n' '        rows.sort((left, right) => {'
    printf '%s\n' '          const a = coerce(cellValue(left, index), type);'
    printf '%s\n' '          const b = coerce(cellValue(right, index), type);'
    printf '%s\n' '          if (a < b) return -1 * multiplier;'
    printf '%s\n' '          if (a > b) return 1 * multiplier;'
    printf '%s\n' '          return 0;'
    printf '%s\n' '        });'
    printf '%s\n' '        rows.forEach(row => tbody.appendChild(row));'
    printf '%s\n' '        table.querySelectorAll("th[aria-sort]").forEach(header => header.removeAttribute("aria-sort"));'
    printf '%s\n' '        th.dataset.direction = direction;'
    printf '%s\n' '        th.setAttribute("aria-sort", direction === "asc" ? "ascending" : "descending");'
    printf '%s\n' '      };'
    printf '%s\n' '      th.addEventListener("click", sort);'
    printf '%s\n' '      th.addEventListener("keydown", event => {'
    printf '%s\n' '        if (event.key === "Enter" || event.key === " ") {'
    printf '%s\n' '          event.preventDefault();'
    printf '%s\n' '          sort();'
    printf '%s\n' '        }'
    printf '%s\n' '      });'
    printf '%s\n' '    });'
    printf '%s\n' '  });'
    printf '%s\n' '})();'
    printf '%s\n' '</script></body></html>'
  } > "$DEP_HTML_REPORT_FILE"
}

if [[ "${SEC_WATCH_FORCE:-0}" != "1" && -n "${UPDATED_AT:-}" && $((now - UPDATED_AT)) -lt "$TTL_SECONDS" ]]; then
  : "${OS_COUNT:=0}" "${DEP_COUNT:=0}" "${DEP_IMPORTANT_COUNT:=0}" "${DEP_CRITICAL_COUNT:=0}" "${DEP_HIGH_COUNT:=0}" "${DEP_MEDIUM_COUNT:=0}" "${DEP_LOW_COUNT:=0}" "${DEP_RECENT_COUNT:=0}" "${DEP_RECENT_CRITICAL_COUNT:=0}" "${DEP_RECENT_HIGH_COUNT:=0}" "${DEP_REPORT_FILE:=$CACHE_DIR/dependency-report.txt}" "${DEP_HTML_REPORT_FILE:=$CACHE_DIR/dependency-report.html}" "${WATCH_COUNT:=0}" "${MANUAL_WATCH_COUNT:=0}" "${CISA_KEV_COUNT:=0}" "${CISA_KEV_RECENT_COUNT:=0}" "${NVD_RECENT_COUNT:=0}" "${RECENT_CHANGE_COUNT:=0}" "${SCANNER:=none}" "${SUMMARY:=cached}"
else
  OS_COUNT=0
  DEP_COUNT=0
  DEP_IMPORTANT_COUNT=0
  DEP_CRITICAL_COUNT=0
  DEP_HIGH_COUNT=0
  DEP_MEDIUM_COUNT=0
  DEP_LOW_COUNT=0
  DEP_RECENT_COUNT=0
  DEP_RECENT_CRITICAL_COUNT=0
  DEP_RECENT_HIGH_COUNT=0
  WATCH_COUNT=0
  MANUAL_WATCH_COUNT=0
  CISA_KEV_COUNT=0
  CISA_KEV_RECENT_COUNT=0
  NVD_RECENT_COUNT=0
  RECENT_CHANGE_COUNT=0
  SCANNER=none
  SUMMARY=""

  if command -v dnf5 >/dev/null 2>&1; then
    os_json="$(dnf5 advisory list --updates --security --with-cve --json 2>/dev/null || true)"
    OS_COUNT="$(printf '%s\n' "$os_json" | jq 'length' 2>/dev/null || printf '0')"
  elif command -v dnf >/dev/null 2>&1; then
    OS_COUNT="$(dnf updateinfo list updates security 2>/dev/null | awk 'NF && $1 ~ /^FEDORA-/ {count++} END {print count + 0}')"
  fi

  if [[ -d "$PROJECTS_DIR" ]]; then
    if command -v osv-scanner >/dev/null 2>&1; then
      SCANNER=osv-scanner
      dep_json="$(osv-scanner scan source -r --format json "$PROJECTS_DIR" 2>/dev/null || true)"
      printf '%s\n' "$dep_json" > "$DEP_JSON_FILE"
      DEP_COUNT="$(printf '%s\n' "$dep_json" | jq '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]?] | length' 2>/dev/null || printf '0')"
      DEP_CRITICAL_COUNT="$(printf '%s\n' "$dep_json" | jq '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]? | select((.database_specific.severity // .severity // "") | ascii_upcase == "CRITICAL")] | length' 2>/dev/null || printf '0')"
      DEP_HIGH_COUNT="$(printf '%s\n' "$dep_json" | jq '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]? | select((.database_specific.severity // .severity // "") | ascii_upcase == "HIGH")] | length' 2>/dev/null || printf '0')"
      DEP_MEDIUM_COUNT="$(printf '%s\n' "$dep_json" | jq '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]? | select((.database_specific.severity // .severity // "") | ascii_upcase == "MEDIUM")] | length' 2>/dev/null || printf '0')"
      DEP_LOW_COUNT="$(printf '%s\n' "$dep_json" | jq '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]? | select((.database_specific.severity // .severity // "") | ascii_upcase == "LOW")] | length' 2>/dev/null || printf '0')"
      DEP_RECENT_COUNT="$(printf '%s\n' "$dep_json" | jq --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" '[.. | objects | select(has("vulnerabilities")) | .vulnerabilities[]? | select(((.modified // .published // "")[0:10]) >= $since)] | length' 2>/dev/null || printf '0')"
    elif command -v trivy >/dev/null 2>&1; then
      SCANNER=trivy
      dep_json="$(trivy fs --scanners vuln --format json "$PROJECTS_DIR" 2>/dev/null || true)"
      dep_json="$(filter_trivy_json "$dep_json")"
      printf '%s\n' "$dep_json" > "$DEP_JSON_FILE"
      DEP_COUNT="$(printf '%s\n' "$dep_json" | jq '[.Results[]?.Vulnerabilities[]?] | length' 2>/dev/null || printf '0')"
      DEP_CRITICAL_COUNT="$(printf '%s\n' "$dep_json" | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL")] | length' 2>/dev/null || printf '0')"
      DEP_HIGH_COUNT="$(printf '%s\n' "$dep_json" | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "HIGH")] | length' 2>/dev/null || printf '0')"
      DEP_MEDIUM_COUNT="$(printf '%s\n' "$dep_json" | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "MEDIUM")] | length' 2>/dev/null || printf '0')"
      DEP_LOW_COUNT="$(printf '%s\n' "$dep_json" | jq '[.Results[]?.Vulnerabilities[]? | select(.Severity == "LOW")] | length' 2>/dev/null || printf '0')"
      DEP_RECENT_COUNT="$(printf '%s\n' "$dep_json" | jq --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL" or .Severity == "HIGH") | select(((.LastModifiedDate // .PublishedDate // "")[0:10]) >= $since)] | length' 2>/dev/null || printf '0')"
      DEP_RECENT_CRITICAL_COUNT="$(printf '%s\n' "$dep_json" | jq --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL") | select(((.LastModifiedDate // .PublishedDate // "")[0:10]) >= $since)] | length' 2>/dev/null || printf '0')"
      DEP_RECENT_HIGH_COUNT="$(printf '%s\n' "$dep_json" | jq --arg since "$(date -d "$RECENT_DAYS days ago" '+%Y-%m-%d')" '[.Results[]?.Vulnerabilities[]? | select(.Severity == "HIGH") | select(((.LastModifiedDate // .PublishedDate // "")[0:10]) >= $since)] | length' 2>/dev/null || printf '0')"
    fi
    DEP_IMPORTANT_COUNT=$((DEP_CRITICAL_COUNT + DEP_HIGH_COUNT))
    if [[ "$SCANNER" == "trivy" ]]; then
      write_trivy_dependency_report "$dep_json"
    elif [[ "$SCANNER" != "none" ]]; then
      {
        printf 'Security dependency report\n'
        printf 'Generated: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
        printf 'Projects: %s\n' "$PROJECTS_DIR"
        printf 'Scanner: %s\n' "$SCANNER"
        printf '\n'
        printf 'Summary\n'
        printf 'Critical: %s\n' "$DEP_CRITICAL_COUNT"
        printf 'High: %s\n' "$DEP_HIGH_COUNT"
        printf 'Medium: %s\n' "$DEP_MEDIUM_COUNT"
        printf 'Low: %s\n' "$DEP_LOW_COUNT"
        printf 'Total: %s\n' "$DEP_COUNT"
        printf '\n'
        printf 'Raw JSON: %s\n' "$DEP_JSON_FILE"
      } > "$DEP_REPORT_FILE"
    fi
  fi

  if [[ -f "$WATCH_CONFIG" ]] && command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    if feed_enabled manual; then
      MANUAL_WATCH_COUNT="$(count_manual_watch_cves)"
    fi
    if feed_enabled cisa-kev; then
      CISA_KEV_COUNT="$(count_cisa_kev_matches)"
      CISA_KEV_RECENT_COUNT="$(count_cisa_kev_matches "$RECENT_DAYS")"
    fi
    if feed_enabled nvd-recent; then
      NVD_RECENT_COUNT="$(count_nvd_recent_matches)"
    fi
    WATCH_COUNT=$((MANUAL_WATCH_COUNT + CISA_KEV_COUNT + NVD_RECENT_COUNT))
  fi

  RECENT_CHANGE_COUNT=$((DEP_RECENT_COUNT + CISA_KEV_RECENT_COUNT + NVD_RECENT_COUNT))
  UPDATED_AT="$now"
  SUMMARY="Fedora: $OS_COUNT, Projects high/critical: $DEP_IMPORTANT_COUNT, Watch: $WATCH_COUNT, Recent: $RECENT_CHANGE_COUNT"
  {
    printf 'UPDATED_AT=%q\n' "$UPDATED_AT"
    printf 'OS_COUNT=%q\n' "$OS_COUNT"
    printf 'DEP_COUNT=%q\n' "$DEP_COUNT"
    printf 'DEP_IMPORTANT_COUNT=%q\n' "$DEP_IMPORTANT_COUNT"
    printf 'DEP_CRITICAL_COUNT=%q\n' "$DEP_CRITICAL_COUNT"
    printf 'DEP_HIGH_COUNT=%q\n' "$DEP_HIGH_COUNT"
    printf 'DEP_MEDIUM_COUNT=%q\n' "$DEP_MEDIUM_COUNT"
    printf 'DEP_LOW_COUNT=%q\n' "$DEP_LOW_COUNT"
    printf 'DEP_RECENT_COUNT=%q\n' "$DEP_RECENT_COUNT"
    printf 'DEP_RECENT_CRITICAL_COUNT=%q\n' "$DEP_RECENT_CRITICAL_COUNT"
    printf 'DEP_RECENT_HIGH_COUNT=%q\n' "$DEP_RECENT_HIGH_COUNT"
    printf 'DEP_REPORT_FILE=%q\n' "$DEP_REPORT_FILE"
    printf 'DEP_HTML_REPORT_FILE=%q\n' "$DEP_HTML_REPORT_FILE"
    printf 'WATCH_COUNT=%q\n' "$WATCH_COUNT"
    printf 'MANUAL_WATCH_COUNT=%q\n' "$MANUAL_WATCH_COUNT"
    printf 'CISA_KEV_COUNT=%q\n' "$CISA_KEV_COUNT"
    printf 'CISA_KEV_RECENT_COUNT=%q\n' "$CISA_KEV_RECENT_COUNT"
    printf 'NVD_RECENT_COUNT=%q\n' "$NVD_RECENT_COUNT"
    printf 'RECENT_CHANGE_COUNT=%q\n' "$RECENT_CHANGE_COUNT"
    printf 'SCANNER=%q\n' "$SCANNER"
    printf 'SUMMARY=%q\n' "$SUMMARY"
  } > "$CACHE_FILE"
fi

case "${1:-argos}" in
  lockfiles)
    list_dependency_watch_files
    ;;
  argos)
    total=$((OS_COUNT + DEP_IMPORTANT_COUNT + WATCH_COUNT))
    if [[ "$total" -gt 0 ]]; then
      echo "Sec: $total | color=#ff6b35"
    elif [[ "$SCANNER" == "none" ]]; then
      echo "Sec: OS | color=#f6c177"
    else
      echo "Sec: OK | color=#66bb6a"
    fi
    echo "---"
    echo "Fedora security advisories: $OS_COUNT"
    echo "Deps critical: $DEP_CRITICAL_COUNT$(format_recent_suffix "$DEP_RECENT_CRITICAL_COUNT")"
    echo "Deps high: $DEP_HIGH_COUNT$(format_recent_suffix "$DEP_RECENT_HIGH_COUNT")"
    echo "Deps medium: $DEP_MEDIUM_COUNT"
    echo "Deps low: $DEP_LOW_COUNT"
    echo "Deps total: $DEP_COUNT"
    echo "Recent changes: $RECENT_CHANGE_COUNT"
    echo "Recent dep changes: $DEP_RECENT_COUNT"
    echo "Watch matches: $WATCH_COUNT"
    echo "Manual watches: $MANUAL_WATCH_COUNT"
    echo "CISA KEV recent matches: $CISA_KEV_COUNT"
    echo "NVD recent high/critical matches: $NVD_RECENT_COUNT"
    echo "Project scanner: $SCANNER"
    echo "Dependency report: $DEP_HTML_REPORT_FILE"
    echo "Text report: $DEP_REPORT_FILE"
    echo "Projects directory: $PROJECTS_DIR"
    echo "Selected projects: ${SELECTED_PROJECTS:-all}"
    echo "Enabled ecosystems: ${ENABLED_ECOSYSTEMS:-all}"
    echo "Public feeds: ${PUBLIC_FEEDS:-none}"
    echo "Watch config: $WATCH_CONFIG"
    echo "Last scan: $(date -d "@$UPDATED_AT" '+%Y-%m-%d %H:%M:%S')"
    echo "---"
    echo "Refresh | bash='SEC_WATCH_FORCE=1 $HOME/.local/bin/sec-watch argos' terminal=false refresh=true"
    echo "Fedora advisories | bash='dnf5 advisory list --updates --security --with-cve' terminal=true"
    if [[ "$SCANNER" == "osv-scanner" ]]; then
      echo "Scan Projects | bash='osv-scanner scan source -r $PROJECTS_DIR' terminal=true"
    elif [[ "$SCANNER" == "trivy" ]]; then
      echo "Scan Projects | bash='trivy fs --scanners vuln $PROJECTS_DIR' terminal=true"
    else
      echo "Install project scanner | bash='printf \"Install osv-scanner or trivy, then refresh.\\n\"; read -r _' terminal=true"
    fi
    ;;
  status)
    echo "$SUMMARY"
    echo "project_total=$DEP_COUNT"
    echo "project_critical=$DEP_CRITICAL_COUNT"
    echo "project_high=$DEP_HIGH_COUNT"
    echo "project_medium=$DEP_MEDIUM_COUNT"
    echo "project_low=$DEP_LOW_COUNT"
    echo "project_recent=$DEP_RECENT_COUNT"
    echo "project_recent_critical=$DEP_RECENT_CRITICAL_COUNT"
    echo "project_recent_high=$DEP_RECENT_HIGH_COUNT"
    echo "recent_changes=$RECENT_CHANGE_COUNT"
    echo "dependency_report=$DEP_REPORT_FILE"
    echo "dependency_html_report=$DEP_HTML_REPORT_FILE"
    echo "scanner=$SCANNER"
    echo "public_feeds=${PUBLIC_FEEDS:-none}"
    echo "watch_config=$WATCH_CONFIG"
    ;;
  *)
    echo "Usage: sec-watch [argos|status]" >&2
    exit 2
    ;;
esac
