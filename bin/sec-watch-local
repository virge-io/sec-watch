#!/usr/bin/env python3

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


BRANCH_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._/-]{0,255}$")


class CommandError(RuntimeError):
    pass


class InputError(ValueError):
    pass


def utc_run_id() -> str:
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    return f"{stamp}-{os.getpid()}"


def default_cache_root() -> Path:
    cache_home = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
    return cache_home / "sec-watch-local"


def script_dir() -> Path:
    return Path(__file__).resolve().parent


def tail(text: str, limit: int = 4000) -> str:
    return text[-limit:] if len(text) > limit else text


def git_env() -> dict[str, str]:
    env = os.environ.copy()
    env["GIT_TERMINAL_PROMPT"] = "0"
    env.setdefault("GIT_SSH_COMMAND", "ssh -o BatchMode=yes")
    return env


def run_command(args: list[str], *, timeout: int, env: dict[str, str] | None = None, check: bool = True) -> subprocess.CompletedProcess[str]:
    try:
        result = subprocess.run(
            args,
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired as error:
        raise CommandError(f"Command timed out after {timeout}s: {args[0]}") from error
    except OSError as error:
        raise CommandError(str(error)) from error

    if check and result.returncode != 0:
        message = tail(result.stderr.strip() or result.stdout.strip() or f"{args[0]} exited {result.returncode}")
        raise CommandError(message)
    return result


def validate_local_path(value: str) -> Path:
    path = Path(value).expanduser().resolve()
    if not path.exists() or not path.is_dir():
        raise InputError("Path must be an existing local directory.")
    return path


def validate_branch(branch: str) -> str:
    branch = branch.strip()
    if not branch:
        raise InputError("Branch is required.")
    if not BRANCH_RE.match(branch):
        raise InputError("Branch contains unsupported characters.")
    if ".." in branch or "//" in branch or branch.endswith("/") or branch.endswith(".lock") or "@{" in branch:
        raise InputError("Branch is not a supported Git branch name.")
    return branch


def git_toplevel(path: Path, timeout: int) -> Path:
    result = run_command(
        ["git", "-C", str(path), "rev-parse", "--show-toplevel"],
        timeout=timeout,
        env=git_env(),
        check=False,
    )
    if result.returncode != 0:
        raise InputError("--branch requires PATH to be inside a local Git repository.")
    return Path(result.stdout.strip()).resolve()


def source_cache_key(path: Path) -> str:
    return hashlib.sha256(str(path).encode("utf-8")).hexdigest()[:24]


def mirror_has_branch(mirror_dir: Path, branch: str, timeout: int) -> bool:
    result = run_command(
        ["git", "-C", str(mirror_dir), "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
        timeout=timeout,
        env=git_env(),
        check=False,
    )
    return result.returncode == 0


def ensure_local_mirror(cache_root: Path, source_path: Path, branch: str, timeout: int) -> Path:
    mirror_dir = cache_root / "repos" / f"{source_cache_key(source_path)}.git"
    mirror_dir.parent.mkdir(parents=True, exist_ok=True)

    if not mirror_dir.exists():
        run_command(["git", "clone", "--mirror", str(source_path), str(mirror_dir)], timeout=timeout, env=git_env())
    else:
        run_command(["git", "-C", str(mirror_dir), "remote", "set-url", "origin", str(source_path)], timeout=timeout, env=git_env())
        run_command(["git", "-C", str(mirror_dir), "remote", "update", "--prune"], timeout=timeout, env=git_env())

    if not mirror_has_branch(mirror_dir, branch, timeout):
        raise InputError(f"Branch not found in local repository: {branch}")

    return mirror_dir


def checkout_branch_worktree(mirror_dir: Path, branch: str, worktree_dir: Path, timeout: int) -> None:
    if worktree_dir.exists():
        shutil.rmtree(worktree_dir)

    run_command(["git", "clone", "--no-checkout", str(mirror_dir), str(worktree_dir)], timeout=timeout, env=git_env())
    run_command(
        ["git", "-C", str(worktree_dir), "fetch", "origin", f"refs/heads/{branch}:refs/remotes/origin/{branch}"],
        timeout=timeout,
        env=git_env(),
    )
    run_command(["git", "-C", str(worktree_dir), "checkout", "--detach", f"refs/remotes/origin/{branch}"], timeout=timeout, env=git_env())


def parse_status(stdout: str) -> dict[str, str]:
    lines = [line.strip() for line in stdout.splitlines() if line.strip()]
    status: dict[str, str] = {"summary": lines[0] if lines else ""}
    for line in lines[1:]:
        key, separator, value = line.partition("=")
        if separator:
            status[key] = value
    return status


def run_scanner(args: argparse.Namespace, scan_path: Path, run_cache_dir: Path) -> subprocess.CompletedProcess[str]:
    scanner = Path(args.scanner).expanduser().resolve()
    if not scanner.exists():
        raise CommandError(f"Scanner not found: {scanner}")

    env = os.environ.copy()
    env["XDG_CACHE_HOME"] = str(run_cache_dir)
    env["SEC_WATCH_PROJECTS_DIR"] = str(scan_path)
    env["SEC_WATCH_PROJECTS"] = ""
    env["SEC_WATCH_OS_ADVISORIES"] = "0"
    env["SEC_WATCH_PUBLIC_FEEDS"] = ""
    env["SEC_WATCH_FORCE"] = "1"

    if args.ecosystems:
        env["SEC_WATCH_ECOSYSTEMS"] = args.ecosystems
    if args.recent_days:
        env["SEC_WATCH_RECENT_DAYS"] = str(args.recent_days)

    return run_command([str(scanner), "status"], timeout=args.scan_timeout, env=env, check=False)


def public_result(source_path: Path, scan_path: Path, status: dict[str, str], result: subprocess.CompletedProcess[str]) -> dict[str, Any]:
    return {
        "source_path": str(source_path),
        "scan_path": str(scan_path),
        "summary": status.get("summary", ""),
        "scanner": status.get("scanner", ""),
        "project_total": status.get("project_total", ""),
        "project_critical": status.get("project_critical", ""),
        "project_high": status.get("project_high", ""),
        "project_medium": status.get("project_medium", ""),
        "project_low": status.get("project_low", ""),
        "dependency_report": status.get("dependency_report", ""),
        "dependency_html_report": status.get("dependency_html_report", ""),
        "exit_code": result.returncode,
    }


def print_human(data: dict[str, Any]) -> None:
    print(data["summary"] or "Scan finished")
    print(f"Scanner: {data['scanner'] or '-'}")
    print(f"Source path: {data['source_path']}")
    print(f"Scan path: {data['scan_path']}")
    print(f"Total: {data['project_total'] or 0}")
    print(f"Critical: {data['project_critical'] or 0}")
    print(f"High: {data['project_high'] or 0}")
    print(f"Medium: {data['project_medium'] or 0}")
    print(f"Low: {data['project_low'] or 0}")
    print(f"HTML report: {data['dependency_html_report'] or '-'}")
    print(f"Text report: {data['dependency_report'] or '-'}")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Scan local files with Security Watch.")
    parser.add_argument("path", nargs="?", default=".", help="Local directory to scan.")
    parser.add_argument("--branch", help="Scan a local Git branch through a cached worktree instead of the current files.")
    parser.add_argument("--cache-root", default=os.environ.get("SEC_WATCH_LOCAL_CACHE", str(default_cache_root())))
    parser.add_argument("--scanner", default=os.environ.get("SEC_WATCH_SCANNER", str(script_dir() / "sec-watch")))
    parser.add_argument("--ecosystems", help="Comma-separated dependency ecosystem filter, for example npm,pip,poetry.")
    parser.add_argument("--recent-days", type=int, help="Lookback window for recent dependency changes.")
    parser.add_argument("--git-timeout", type=int, default=int(os.environ.get("SEC_WATCH_LOCAL_GIT_TIMEOUT", "300")))
    parser.add_argument("--scan-timeout", type=int, default=int(os.environ.get("SEC_WATCH_LOCAL_SCAN_TIMEOUT", "1800")))
    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON.")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])

    try:
        source_path = validate_local_path(args.path)
        cache_root = Path(args.cache_root).expanduser().resolve()
        run_dir = cache_root / "jobs" / utc_run_id()
        run_cache_dir = run_dir / "cache"
        run_cache_dir.mkdir(parents=True, exist_ok=True)

        scan_path = source_path
        if args.branch:
            branch = validate_branch(args.branch)
            repo_path = git_toplevel(source_path, args.git_timeout)
            mirror_dir = ensure_local_mirror(cache_root, repo_path, branch, args.git_timeout)
            scan_path = run_dir / "worktree"
            checkout_branch_worktree(mirror_dir, branch, scan_path, args.git_timeout)

        result = run_scanner(args, scan_path, run_cache_dir)
        status = parse_status(result.stdout)
        data = public_result(source_path, scan_path, status, result)

        if args.json:
            print(json.dumps(data, indent=2, sort_keys=True))
        else:
            print_human(data)

        if result.returncode != 0:
            if result.stderr:
                print(tail(result.stderr), file=sys.stderr)
            return result.returncode
        return 0
    except (InputError, CommandError) as error:
        if args.json:
            print(json.dumps({"error": str(error)}, indent=2, sort_keys=True))
        else:
            print(f"sec-watch-local: {error}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
